        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StockSense.WPF"
        mc:Ignorable="d"
        Title="StockSense" Height="600" Width="1000">
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="520">
            <TextBlock Text="StockSense" FontSize="28" FontWeight="SemiBold" HorizontalAlignment="Center" />
